                        <button type="button" class="btn-close-custom" data-bs-dismiss="modal" aria-label="Close">
                            <lord-icon src="https://cdn.lordicon.com/nqtddedc.json"
                                       trigger="hover"
                                       colors="primary:#6b7280"
                                       style="width:24px;height:24px"></lord-icon>
                        </button>
                    </div>
                    <div class="modal-body">
                        <div class="delete-warning">
                            <lord-icon src="https://cdn.lordicon.com/tdrtiskw.json"
                                       trigger="loop"
                                       colors="primary:#FF6B6B"
                                       style="width:100px;height:100px"></lord-icon>

                            <h4>¿Estás seguro?</h4>
                            <p>Vas a eliminar el consumo:</p>

                            <div class="delete-client-name">
                                <lord-icon src="https://cdn.lordicon.com/hrjifpbq.json"
                                           trigger="hover"
                                           colors="primary:#FF6B6B"
                                           style="width:24px;height:24px"></lord-icon>
                                <strong>Consumo #@consumo.IdConsumo - Mesa @consumo.Mesa?.NumeroMesa</strong>
                            </div>

                            <div class="delete-alert">
                                <lord-icon src="https://cdn.lordicon.com/keaiyjcx.json"
                                           trigger="loop"
                                           colors="primary:#FF6B6B"
                                           style="width:20px;height:20px"></lord-icon>
                                Esta acción no se puede deshacer
