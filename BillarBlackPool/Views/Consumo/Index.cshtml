                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="modal-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <form asp-action="Delete" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@consumo.IdConsumo" />
                            <button type="submit" class="modal-btn-danger">
                                <lord-icon src="https://cdn.lordicon.com/wpyrrmcq.json"
                                           trigger="hover"
                                           colors="primary:#ffffff"
                                           style="width:20px;height:20px"></lord-icon>
                                Eliminar Consumo
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
}

@section Scripts {
    <script>
        // BÚSQUEDA EN TIEMPO REAL
        document.addEventListener('DOMContentLoaded', function () {
            const searchInput = document.getElementById('searchInput');
            const clearSearch = document.getElementById('clearSearch');
            const table = document.getElementById('consumosTable');
            const noResults = document.getElementById('noResultsMessage');

            const pad = (n) => String(n).padStart(2, '0');
            const formatDuration = (totalSeconds) => {
                const safe = Math.max(0, Math.floor(totalSeconds));
                const h = Math.floor(safe / 3600);
                const m = Math.floor((safe % 3600) / 60);
                const s = safe % 60;
                return `${pad(h)}:${pad(m)}:${pad(s)}`;
            };

            const formatDateTime = (date) => {
                return new Intl.DateTimeFormat('es-PE', {
                    day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit'
                }).format(date);
            };

            const refreshTimers = () => {
                document.querySelectorAll('.cliente-row').forEach(row => {
                    const fechaInicio = row.getAttribute('data-fecha-inicio');
                    const fechaFin = row.getAttribute('data-fecha-fin');
                    const tipoCobro = row.getAttribute('data-tipo-cobro') || 'Libre';
                    const precioMinuto = parseFloat(row.getAttribute('data-precio-minuto') || '0.1');
                    const precioHora = parseFloat(row.getAttribute('data-precio-hora') || '6');
                    const precioMedia = parseFloat(row.getAttribute('data-precio-mediahora') || '3');

                    const inicio = new Date(fechaInicio);
                    const fin = fechaFin ? new Date(fechaFin) : new Date();
                    const elapsedSeconds = (fin - inicio) / 1000;
                    const elapsedMinutes = elapsedSeconds / 60;

                    const tiempoCell = row.querySelector('.js-tiempo');
                    const minutosCell = row.querySelector('.js-minutos');
                    const costoCell = row.querySelector('.js-costo-mesa');
                    const totalCell = row.querySelector('.js-total');

                    if (tiempoCell) tiempoCell.textContent = formatDuration(elapsedSeconds);
                    if (minutosCell) minutosCell.textContent = String(Math.max(0, Math.ceil(elapsedMinutes)));

                    let costoMesa = 0;
                    if (tipoCobro === 'Hora') {
                        costoMesa = fechaFin ? precioHora : precioHora * (elapsedMinutes / 60);
                    } else if (tipoCobro === 'MediaHora') {
                        costoMesa = fechaFin ? precioMedia : precioMedia * (elapsedMinutes / 30);
                    } else {
                        costoMesa = elapsedMinutes * precioMinuto;
                    }

                    if (costoCell) costoCell.textContent = `S/ ${costoMesa.toFixed(2)}`;

                    const totalProductos = 0;
                    const total = costoMesa + totalProductos;
                    if (totalCell) totalCell.textContent = `S/ ${total.toFixed(2)}`;

                    if (tipoCobro === 'Hora' || tipoCobro === 'MediaHora') {
                        const finEstimado = tipoCobro === 'Hora'
                            ? new Date(inicio.getTime() + 60 * 60000)
                            : new Date(inicio.getTime() + 30 * 60000);
                        row.setAttribute('title', `Inicio: ${formatDateTime(inicio)} | Fin estimado: ${formatDateTime(finEstimado)}`);
                    } else {
                        row.setAttribute('title', `Inicio: ${formatDateTime(inicio)} | Tiempo en vivo`);
                    }
                });
            };

            if (table) {
                setInterval(refreshTimers, 1000);
                refreshTimers();
            }

            if (searchInput && table) {
                searchInput.addEventListener('input', function () {
                    const searchTerm = this.value.toLowerCase();
                    const rows = table.querySelectorAll('tbody tr');
                    let visibleCount = 0;

                    rows.forEach(row => {
                        const text = row.textContent.toLowerCase();
                        if (text.includes(searchTerm)) {
                            row.style.display = '';
                            visibleCount++;
                        } else {
                            row.style.display = 'none';
                        }
                    });

                    if (noResults) noResults.style.display = (visibleCount === 0) ? 'flex' : 'none';
                    if (clearSearch) clearSearch.style.display = searchTerm ? 'flex' : 'none';
                });

                if (clearSearch) {
                    clearSearch.addEventListener('click', function () {
                        searchInput.value = '';
                        searchInput.dispatchEvent(new Event('input'));
                        searchInput.focus();
                    });
                }
            }

            // ANIMACIÓN DE FILAS
            const rows = document.querySelectorAll('.cliente-row');
            rows.forEach((row, index) => {
                row.style.animation = `fadeInUp 0.5s ease forwards ${index * 0.05}s`;
                row.style.opacity = '0';
            });
        });
    </script>
}