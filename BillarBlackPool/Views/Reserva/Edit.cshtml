@model BillarBlackPool.Models.Reserva

@{
    ViewData["Title"] = "Editar Reserva";
}

<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;700;900&display=swap" rel="stylesheet" />
<script src="https://cdn.lordicon.com/lordicon.js"></script>
<link href="~/css/Reserva.css" rel="stylesheet" />

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

            <!-- Card del formulario -->
            <div class="cliente-form-card">

                <!-- Header -->
                <div class="cliente-form-header">
                    <div class="cliente-form-icon-wrapper">
                        <lord-icon src="https://cdn.lordicon.com/wuvorxbv.json"
                                   trigger="loop"
                                   colors="primary:#ffffff,secondary:#ffffff"
                                   style="width:60px;height:60px">
                        </lord-icon>
                    </div>
                    <h2 class="cliente-form-title mb-2">Editar Reserva</h2>
                    <p class="cliente-form-subtitle">Modificar información de la reserva #@Model.IdReserva</p>
                </div>

                <!-- Formulario -->
                <form asp-action="Edit" method="post" class="cliente-form" id="formReservaEdit">
                    @Html.AntiForgeryToken()
                    <!-- Hidden fields -->
                    <input type="hidden" asp-for="IdReserva" />

                    <div class="row g-4">
                        <!-- Información de la reserva -->
                        <div class="col-12">
                            <div class="cliente-info-box">
                                <lord-icon src="https://cdn.lordicon.com/abfverha.json"
                                           trigger="loop"
                                           colors="primary:#6CA8FF"
                                           style="width:28px;height:28px">
                                </lord-icon>
                                <div>
                                    <strong>Información de la Reserva:</strong><br />
                                    <strong>Cliente Actual:</strong> @Model.Cliente?.Nombre<br />
                                    <strong>Mesa Actual:</strong> Mesa @Model.Mesa?.NumeroMesa<br />
                                    <strong>Estado Actual:</strong>
                                    @{
                                        var estadoClass = Model.Estado switch
                                        {
                                            "Pendiente" => "estado-badge estado-pendiente",
                                            "Confirmada" => "estado-badge estado-confirmada",
                                            "Cancelada" => "estado-badge estado-cancelada",
                                            "Completada" => "estado-badge estado-completada",
                                            _ => "estado-badge estado-pendiente"
                                        };
                                    }
                                    <span class="@estadoClass">@Model.Estado</span>
                                </div>
                            </div>
                        </div>

                        <!-- Mesa -->
                        <div class="col-md-6">
                            <div class="cliente-field">
                                <label asp-for="IdMesa" class="cliente-label">
                                    <lord-icon src="https://cdn.lordicon.com/srsgifqc.json"
                                               trigger="hover"
                                               colors="primary:#6CA8FF"
                                               style="width:24px;height:24px">
                                    </lord-icon>
                                    <span>Mesa</span>
                                    <span class="required-asterisk">*</span>
                                </label>
                                <div class="input-wrapper">
                                    <select asp-for="IdMesa" class="cartoon-input" required>
                                        <option value="">-- Seleccione una mesa --</option>
                                        @if (ViewBag.Mesas != null)
                                        {
                                            @foreach (var item in ViewBag.Mesas)
                                            {
                                                <option value="@item.Value" selected="@(item.Value == Model.IdMesa.ToString())">
                                                    @item.Text
                                                </option>
                                            }
                                        }
                                    </select>
                                    <div class="input-icon">
                                        <lord-icon src="https://cdn.lordicon.com/dxjqoygy.json"
                                                   trigger="hover"
                                                   colors="primary:#6CA8FF"
                                                   style="width:20px;height:20px">
                                        </lord-icon>
                                    </div>
                                </div>
                                <span asp-validation-for="IdMesa" class="validation-message"></span>
                            </div>
                        </div>

                        <!-- Cliente -->
                        <div class="col-md-6">
                            <div class="cliente-field">
                                <label asp-for="IdCliente" class="cliente-label">
                                    <lord-icon src="https://cdn.lordicon.com/hrjifpbq.json"
                                               trigger="hover"
                                               colors="primary:#6CA8FF"
                                               style="width:24px;height:24px">
                                    </lord-icon>
                                    <span>Cliente</span>
                                    <span class="required-asterisk">*</span>
                                </label>
                                <div class="input-wrapper">
                                    <select asp-for="IdCliente" class="cartoon-input" required>
                                        <option value="">-- Seleccione un cliente --</option>
                                        @if (ViewBag.Clientes != null)
                                        {
                                            @foreach (var item in ViewBag.Clientes)
                                            {
                                                <option value="@item.Value" selected="@(item.Value == Model.IdCliente.ToString())">
                                                    @item.Text
                                                </option>
                                            }
                                        }
                                    </select>
                                    <div class="input-icon">
                                        <lord-icon src="https://cdn.lordicon.com/dxjqoygy.json"
                                                   trigger="hover"
                                                   colors="primary:#6CA8FF"
                                                   style="width:20px;height:20px">
                                        </lord-icon>
                                    </div>
                                </div>
                                <span asp-validation-for="IdCliente" class="validation-message"></span>
                            </div>
                        </div>

                        <!-- Fecha de Reserva -->
                        <div class="col-md-6">
                            <div class="cliente-field">
                                <label asp-for="FechaReserva" class="cliente-label">
                                    <lord-icon src="https://cdn.lordicon.com/abvsilkn.json"
                                               trigger="hover"
                                               colors="primary:#6CA8FF"
                                               style="width:24px;height:24px">
                                    </lord-icon>
                                    <span>Fecha de Reserva</span>
                                    <span class="required-asterisk">*</span>
                                </label>
                                <div class="input-wrapper">
                                    @{
                                        var fechaReservaValue = Model.FechaReserva.ToString("yyyy-MM-dd");
                                    }
                                    <input asp-for="FechaReserva"
                                           type="date"
                                           value="@fechaReservaValue"
                                           class="cartoon-input"
                                           required />
                                    <div class="input-icon">
                                        <lord-icon src="https://cdn.lordicon.com/dxjqoygy.json"
                                                   trigger="hover"
                                                   colors="primary:#6CA8FF"
                                                   style="width:20px;height:20px">
                                        </lord-icon>
                                    </div>
                                </div>
                                <span asp-validation-for="FechaReserva" class="validation-message"></span>
                            </div>
                        </div>

                        <!-- Número de Personas -->
                        <div class="col-md-6">
                            <div class="cliente-field">
                                <label asp-for="NumeroPersonas" class="cliente-label">
                                    <lord-icon src="https://cdn.lordicon.com/zzcjjxew.json"
                                               trigger="hover"
                                               colors="primary:#6CA8FF"
                                               style="width:24px;height:24px">
                                    </lord-icon>
                                    <span>Número de Personas</span>
                                    <span class="required-asterisk">*</span>
                                </label>
                                <div class="input-wrapper">
                                    <input asp-for="NumeroPersonas"
                                           type="number"
                                           min="1"
                                           max="20"
                                           class="cartoon-input"
                                           placeholder="Ej: 4"
                                           required />
                                    <div class="input-icon">
                                        <lord-icon src="https://cdn.lordicon.com/dxjqoygy.json"
                                                   trigger="hover"
                                                   colors="primary:#6CA8FF"
                                                   style="width:20px;height:20px">
                                        </lord-icon>
                                    </div>
                                </div>
                                <span asp-validation-for="NumeroPersonas" class="validation-message"></span>
                            </div>
                        </div>

                        <!-- Hora de Inicio (Programada) -->
                        <div class="col-md-6">
                            <div class="cliente-field">
                                <label asp-for="HoraInicio" class="cliente-label">
                                    <lord-icon src="https://cdn.lordicon.com/ehiglnfr.json"
                                               trigger="hover"
                                               colors="primary:#6CA8FF"
                                               style="width:24px;height:24px">
                                    </lord-icon>
                                    <span>Hora de Inicio (Programada)</span>
                                    <span class="required-asterisk">*</span>
                                </label>
                                <div class="input-wrapper">
                                    @{
                                        var horaInicioValue = Model.HoraInicio.ToString(@"hh\:mm");
                                    }
                                    <input asp-for="HoraInicio"
                                           type="time"
                                           value="@horaInicioValue"
                                           class="cartoon-input"
                                           required />
                                    <div class="input-icon">
                                        <lord-icon src="https://cdn.lordicon.com/dxjqoygy.json"
                                                   trigger="hover"
                                                   colors="primary:#6CA8FF"
                                                   style="width:20px;height:20px">
                                        </lord-icon>
                                    </div>
                                </div>
                                <span asp-validation-for="HoraInicio" class="validation-message"></span>
                            </div>
                        </div>

                        <!-- Hora de Fin (Programada) -->
                        <div class="col-md-6">
                            <div class="cliente-field">
                                <label asp-for="HoraFin" class="cliente-label">
                                    <lord-icon src="https://cdn.lordicon.com/ehiglnfr.json"
                                               trigger="hover"
                                               colors="primary:#6CA8FF"
                                               style="width:24px;height:24px">
                                    </lord-icon>
                                    <span>Hora de Fin (Programada)</span>
                                    <span class="required-asterisk">*</span>
                                </label>
                                <div class="input-wrapper">
                                    @{
                                        var horaFinValue = Model.HoraFin.ToString(@"hh\:mm");
                                    }
                                    <input asp-for="HoraFin"
                                           type="time"
                                           value="@horaFinValue"
                                           class="cartoon-input"
                                           required />
                                    <div class="input-icon">
                                        <lord-icon src="https://cdn.lordicon.com/dxjqoygy.json"
                                                   trigger="hover"
                                                   colors="primary:#6CA8FF"
                                                   style="width:20px;height:20px">
                                        </lord-icon>
                                    </div>
                                </div>
                                <span asp-validation-for="HoraFin" class="validation-message"></span>
                            </div>
                        </div>

                        <!-- 🆕 Fecha/Hora Inicio del Juego (Real) -->
                        <div class="col-md-6">
                            <div class="cliente-field">
                                <label asp-for="FechaHoraInicioJuego" class="cliente-label">
                                    <lord-icon src="https://cdn.lordicon.com/flcstobf.json"
                                               trigger="hover"
                                               colors="primary:#6CA8FF"
                                               style="width:24px;height:24px">
                                    </lord-icon>
                                    <span>Fecha/Hora Inicio del Juego (Real)</span>
                                </label>
                                <div class="input-wrapper">
                                    @{
                                        var fechaHoraInicioValue = Model.FechaHoraInicioJuego.HasValue
                                        ? Model.FechaHoraInicioJuego.Value.ToString("yyyy-MM-ddTHH:mm")
                                        : "";
                                    }
                                    <input asp-for="FechaHoraInicioJuego"
                                           type="datetime-local"
                                           value="@fechaHoraInicioValue"
                                           class="cartoon-input" />
                                    <div class="input-icon">
                                        <lord-icon src="https://cdn.lordicon.com/dxjqoygy.json"
                                                   trigger="hover"
                                                   colors="primary:#6CA8FF"
                                                   style="width:20px;height:20px">
                                        </lord-icon>
                                    </div>
                                </div>
                                <span asp-validation-for="FechaHoraInicioJuego" class="validation-message"></span>
                            </div>
                        </div>

                        <!-- 🆕 Fecha/Hora Fin del Juego (Real) -->
                        <div class="col-md-6">
                            <div class="cliente-field">
                                <label asp-for="FechaHoraFinJuego" class="cliente-label">
                                    <lord-icon src="https://cdn.lordicon.com/jxwksmzq.json"
                                               trigger="hover"
                                               colors="primary:#6CA8FF"
                                               style="width:24px;height:24px">
                                    </lord-icon>
                                    <span>Fecha/Hora Fin del Juego (Real)</span>
                                </label>
                                <div class="input-wrapper">
                                    @{
                                        var fechaHoraFinValue = Model.FechaHoraFinJuego.HasValue
                                        ? Model.FechaHoraFinJuego.Value.ToString("yyyy-MM-ddTHH:mm")
                                        : "";
                                    }
                                    <input asp-for="FechaHoraFinJuego"
                                           type="datetime-local"
                                           value="@fechaHoraFinValue"
                                           class="cartoon-input" />
                                    <div class="input-icon">
                                        <lord-icon src="https://cdn.lordicon.com/dxjqoygy.json"
                                                   trigger="hover"
                                                   colors="primary:#6CA8FF"
                                                   style="width:20px;height:20px">
                                        </lord-icon>
                                    </div>
                                </div>
                                <span asp-validation-for="FechaHoraFinJuego" class="validation-message"></span>
                            </div>
                        </div>

                        <!-- Estado -->
                        <div class="col-12">
                            <div class="cliente-field">
                                <label asp-for="Estado" class="cliente-label">
                                    <lord-icon src="https://cdn.lordicon.com/diihvcfp.json"
                                               trigger="hover"
                                               colors="primary:#6CA8FF"
                                               style="width:24px;height:24px">
                                    </lord-icon>
                                    <span>Estado</span>
                                    <span class="required-asterisk">*</span>
                                </label>
                                <div class="input-wrapper">
                                    <select asp-for="Estado" class="cartoon-input" required>
                                        <option value="Pendiente" selected="@(Model.Estado == "Pendiente")">Pendiente</option>
                                        <option value="Confirmada" selected="@(Model.Estado == "Confirmada")">Confirmada</option>
                                        <option value="Cancelada" selected="@(Model.Estado == "Cancelada")">Cancelada</option>
                                        <option value="Completada" selected="@(Model.Estado == "Completada")">Completada</option>
                                    </select>
                                    <div class="input-icon">
                                        <lord-icon src="https://cdn.lordicon.com/dxjqoygy.json"
                                                   trigger="hover"
                                                   colors="primary:#6CA8FF"
                                                   style="width:20px;height:20px">
                                        </lord-icon>
                                    </div>
                                </div>
                                <span asp-validation-for="Estado" class="validation-message"></span>
                            </div>
                        </div>
                    </div>

                    <!-- 🆕 Caja informativa sobre campos opcionales -->
                    <div class="cliente-info-box mt-4">
                        <lord-icon src="https://cdn.lordicon.com/abfverha.json"
                                   trigger="loop"
                                   colors="primary:#6CA8FF"
                                   style="width:28px;height:28px">
                        </lord-icon>
                        <div>
                            <strong>Información:</strong> Los campos de Fecha/Hora Real <strong>no son obligatorios</strong> y se usarán para el control de tiempo de juego efectivo.
                        </div>
                    </div>

                    <!-- Caja de advertencia -->
                    <div class="cliente-warning-box mt-4">
                        <lord-icon src="https://cdn.lordicon.com/keaiyjcx.json"
                                   trigger="loop"
                                   colors="primary:#FFB86C"
                                   style="width:28px;height:28px">
                        </lord-icon>
                        <div>
                            <strong>Atención:</strong> Revisa cuidadosamente los cambios antes de guardar.
                            El sistema verificará la disponibilidad de la mesa al guardar los cambios.
                        </div>
                    </div>

                    <!-- Botones -->
                    <div class="cliente-form-actions mt-5">
                        <a asp-action="Index" class="cliente-btn-cancel cartoon-btn-secondary">
                            <lord-icon src="https://cdn.lordicon.com/nqtddedc.json"
                                       trigger="hover"
                                       colors="primary:#ffffff"
                                       style="width:22px;height:22px">
                            </lord-icon>
                            <span>Cancelar</span>
                        </a>

                        <button type="submit" class="cliente-btn-submit cartoon-btn-primary">
                            <lord-icon src="https://cdn.lordicon.com/dangivhk.json"
                                       trigger="hover"
                                       colors="primary:#ffffff"
                                       style="width:22px;height:22px">
                            </lord-icon>
                            <span>Guardar Cambios</span>
                        </button>
                    </div>

                </form>

            </div>

            <!-- Link de retorno -->
            <div class="text-center mt-4">
                <a asp-action="Index" class="cliente-back-link">
                    ← Volver a la lista de reservas
                </a>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Validación en tiempo real
        document.getElementById('formReservaEdit').addEventListener('submit', function(e) {
            const inputs = this.querySelectorAll('input[required], select[required]');
            let isValid = true;

            inputs.forEach(input => {
                if (!input.value.trim()) {
                    isValid = false;
                    input.classList.add('input-error');
                } else {
                    input.classList.remove('input-error');
                }
            });

            if (!isValid) {
                e.preventDefault();
            }
        });

        // Efectos de focus
        document.querySelectorAll('.cartoon-input:not([readonly])').forEach(input => {
            input.addEventListener('focus', function() {
                this.parentElement.classList.add('input-focused');
            });

            input.addEventListener('blur', function() {
                this.parentElement.classList.remove('input-focused');
            });
        });

        // Validación de número de personas
        const personasInput = document.querySelector('input[asp-for="NumeroPersonas"]');
        if (personasInput) {
            personasInput.addEventListener('input', function() {
                if (this.value < 1) {
                    this.value = 1;
                }
                if (this.value > 20) {
                    this.value = 20;
                }
            });
        }

        // Detectar cambios sin guardar
        let formChanged = false;
        document.querySelectorAll('.cartoon-input:not([readonly])').forEach(input => {
            input.addEventListener('input', function() {
                formChanged = true;
            });
        });

        // Advertencia al salir
        window.addEventListener('beforeunload', function(e) {
            if (formChanged) {
                e.preventDefault();
                e.returnValue = '';
            }
        });

        // No advertir al guardar
        document.getElementById('formReservaEdit').addEventListener('submit', function() {
            formChanged = false;
        });
    </script>
}