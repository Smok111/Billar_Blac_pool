@model BillarBlackPool.Models.ConsumoDetalle
@{
    ViewData["Title"] = "Nuevo Detalle de Consumo";
}

<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;700;900&display=swap" rel="stylesheet">
<link href="~/css/ConsumoDetalle.css" rel="stylesheet" />
<script src="https://cdn.lordicon.com/lordicon.js"></script>

<div class="container mt-5 mb-5">

    <div class="detalle-header-wrapper">
        <div class="detalle-header-content">
            <div class="detalle-header-left">
                <div class="detalle-header-icon">
                    <lord-icon src="https://cdn.lordicon.com/urhcgqxz.json" trigger="loop" state="hover-looking-around" colors="primary:#38a169,secondary:#4299e1" style="width:70px;height:70px"></lord-icon>
                </div>
                <div>
                    <h2 class="detalle-title">Nuevo Detalle de Consumo</h2>
                    <p class="detalle-subtitle">Agrega uno o varios productos al consumo seleccionado</p>
                </div>
            </div>
            <div>
                <a asp-action="Index" class="btn btn-sm btn-secondary">
                    <i class="bi bi-arrow-left-circle-fill me-1"></i> Volver a la Lista
                </a>
            </div>
        </div>
    </div>

    <div class="detalle-card p-4">

        <div class="mb-4">
            <label class="detalle-label">
                <i class="bi bi-receipt-cutoff me-1"></i> Consumo: <span class="required-asterisk">*</span>
            </label>
            @Html.DropDownListFor(
                m => m.IdConsumo,
                (SelectList)ViewData["IdConsumo"],
                "-- Seleccione --",
                new { @class = "form-control fila-producto", id = "idConsumo" }
            )
        </div>

        <div class="table-responsive">
            <table class="table table-hover detalle-table" id="tablaProductos">
                <thead>
                    <tr>
                        <th style="width: 35%;">Producto</th>
                        <th class="text-center" style="width: 15%;">Cantidad</th>
                        <th class="text-center" style="width: 15%;">Precio Unit.</th>
                        <th class="text-center" style="width: 15%;">Subtotal</th>
                        <th class="text-center" style="width: 15%;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="fila-producto">
                        <td>
                            <select class="form-control producto-select">
                                <option value="">-- Seleccione --</option>
                                @{ var gruposProductos = ((IEnumerable<dynamic>)ViewBag.ProductosConPrecio).GroupBy(p => p.Nombre == null ? "Sin categoría" : p.Nombre.ToString()); }
                                @foreach (var grupo in gruposProductos)
                                {
                                    <optgroup label="@grupo.Key">
                                        @foreach (var p in grupo)
                                        {
                                            <option value="@p.IdProducto" data-precio="@p.Precio">@p.Nombre</option>
                                        }
                                    </optgroup>
                                }
                            </select>
                        </td>
                        <td>
                            <input type="number" class="form-control cantidad text-center" value="1" min="1" />
                        </td>
                        <td>
                            <input type="text" class="form-control precio text-center" readonly />
                        </td>
                        <td>
                            <input type="text" class="form-control subtotal text-center" readonly />
                        </td>
                        <td class="text-center">
                            <button type="button" class="btn btn-danger btn-sm btn-remove">
                                <i class="bi bi-x-circle-fill"></i> Eliminar
                            </button>
                        </td>
                    </tr>
                </tbody>
                <tfoot>
                    <tr class="fw-bold">
                        <td colspan="3" class="text-end">TOTAL GENERAL:</td>
                        <td>
                            <input type="text" id="totalGeneral" class="form-control text-center" readonly value="0.00" />
                        </td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="mt-4 detalle-form-actions">
            <button type="button" class="btn" id="btnAgregar">
                <i class="bi bi-plus-square-fill me-2"></i> Agregar Producto
            </button>

            <button type="button" class="btn" id="btnGuardar">
                <i class="bi bi-check-circle-fill me-2"></i> Guardar Todos
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            function actualizarFila(fila) {
                var precio = parseFloat(fila.find('.producto-select option:selected').data('precio') || 0);
                var cantidad = parseInt(fila.find('.cantidad').val() || 1);
                fila.find('.precio').val(precio.toFixed(2));
                fila.find('.subtotal').val((precio * cantidad).toFixed(2));
                actualizarTotalGeneral();
            }

            function actualizarTotalGeneral() {
                var total = 0;
                $('#tablaProductos tbody tr').each(function () {
                    var subtotal = parseFloat($(this).find('.subtotal').val() || 0);
                    total += subtotal;
                });
                $('#totalGeneral').val(total.toFixed(2));
            }

            $(document).on('change', '.producto-select', function () {
                actualizarFila($(this).closest('tr'));
            });

            $(document).on('input', '.cantidad', function () {
                actualizarFila($(this).closest('tr'));
            });

            $('#btnAgregar').click(function () {
                var filaOriginal = $('#tablaProductos tbody tr:first');
                var nuevaFila = filaOriginal.clone();
                nuevaFila.find('select').val('');
                nuevaFila.find('.cantidad').val(1);
                nuevaFila.find('.precio').val('');
                nuevaFila.find('.subtotal').val('');
                $('#tablaProductos tbody').append(nuevaFila);
            });

            $(document).on('click', '.btn-remove', function () {
                if ($('#tablaProductos tbody tr').length > 1) {
                    $(this).closest('tr').remove();
                } else {
                    alert('Debe haber al menos un producto seleccionado.');
                }
                actualizarTotalGeneral();
            });

            $('#btnGuardar').click(function () {
                var productos = [];
                var idConsumo = $('#idConsumo').val();

                if (!idConsumo) { alert('Seleccione un consumo'); return; }

                $('#tablaProductos tbody tr').each(function () {
                    var idProducto = $(this).find('.producto-select').val();
                    var cantidad = parseInt($(this).find('.cantidad').val());

                    if (idProducto && cantidad > 0) {
                        productos.push({
                            IdConsumo: parseInt(idConsumo),
                            IdProducto: parseInt(idProducto),
                            Cantidad: cantidad
                        });
                    }
                });

                if (productos.length === 0) { alert('No hay productos válidos para guardar'); return; }

                $.ajax({
                    url: '@Url.Action("CreateMultiple", "ConsumoDetalle")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(productos),
                    success: function (res) {
                        if (res.success) {
                            alert(res.message);
                            window.location.href = '@Url.Action("Index")';
                        } else {
                            alert(res.message);
                        }
                    },
                    error: function (xhr, status, error) {
                        alert("Ocurrió un error al guardar los detalles: " + error);
                    }
                });
            });

            actualizarFila($('#tablaProductos tbody tr:first'));
        });
    </script>
}