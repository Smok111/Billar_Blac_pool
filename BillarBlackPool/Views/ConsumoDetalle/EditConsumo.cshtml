@model List<BillarBlackPool.Models.ConsumoDetalle>

@{
    ViewData["Title"] = "Editar Consumo ";
    var idConsumo = (int)ViewBag.IdConsumo;
}

<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;700;900&display=swap" rel="stylesheet">
<script src="https://cdn.lordicon.com/lordicon.js"></script>
<link href="~/css/ConsumoDetalle.css" rel="stylesheet" />

<div class="container mt-5 mb-5">
    <div class="detalle-header-wrapper">
        <h2 class="detalle-title">Editar Detalles del Consumo #@idConsumo</h2>
        <p class="detalle-subtitle">Modifica los productos y cantidades de este consumo.</p>
    </div>

    <div class="detalle-card p-4">
        <div class="mb-3">
            <label>Consumo:</label>
            <input value="@idConsumo" class="form-control" readonly />
        </div>

        <table class="table table-hover detalle-table" id="tablaProductos">
            <thead>
                <tr>
                    <th>Producto</th>
                    <th>Cantidad</th>
                    <th>Precio Unit.</th>
                    <th>Subtotal</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var detalle in Model)
                    {
                        <tr class="fila-producto" data-iddetalle="@detalle.IdDetalle">
                            <input type="hidden" class="iddetalle" value="@detalle.IdDetalle" />
                            <td>
                                <select class="form-control producto-select">
                                    <option value="">-- Seleccione --</option>
                                    @foreach (var p in ViewBag.ProductosConPrecio)
                                    {
                                        bool isSelected = (int)p.IdProducto == detalle.IdProducto;
                                        <option value="@p.IdProducto" data-precio="@p.Precio" selected="@isSelected">@p.Nombre</option>
                                    }
                                </select>
                            </td>
                            <td><input type="number" class="form-control cantidad" value="@detalle.Cantidad" min="1" /></td>
                            <td><input type="text" class="form-control precio" readonly value="@detalle.PrecioUnitario.ToString("F2")" /></td>
                            <td><input type="text" class="form-control subtotal" readonly value="@((detalle.Cantidad * detalle.PrecioUnitario).ToString("F2"))" /></td>
                            <td><button type="button" class="btn btn-danger btn-remove">Eliminar</button></td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot>
                <tr class="fw-bold">
                    <td colspan="3" class="text-end">TOTAL GENERAL:</td>
                    <td><input type="text" id="totalGeneral" class="form-control" readonly value="0.00" /></td>
                    <td></td>
                </tr>
            </tfoot>
        </table>

        <div class="mt-3">
            <button type="button" class="btn btn-primary" id="btnAgregar">
                <lord-icon src="https://cdn.lordicon.com/mecwbjnp.json" colors="primary:#ffffff" style="width:24px;height:24px"></lord-icon>
                Agregar Producto
            </button>

            <button type="button" class="btn btn-success" id="btnGuardar">
                <lord-icon src="https://cdn.lordicon.com/udbbfuld.json" colors="primary:#ffffff" style="width:24px;height:24px"></lord-icon>
                Guardar Cambios
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            var idConsumo = @idConsumo; // ID del consumo

        
            var filaPlantilla = `
                <tr class="fila-producto" data-iddetalle="0">
                    <input type="hidden" class="iddetalle" value="0" />
                    <td>
                        <select class="form-control producto-select">
                            <option value="">-- Seleccione --</option>
                            @foreach (var p in ViewBag.ProductosConPrecio)
                            {
                                    <option value="@p.IdProducto" data-precio="@p.Precio">@p.Nombre</option>
                            }
                        </select>
                    </td>
                    <td><input type="number" class="form-control cantidad" value="1" min="1" /></td>
                    <td><input type="text" class="form-control precio" readonly /></td>
                    <td><input type="text" class="form-control subtotal" readonly /></td>
                    <td><button type="button" class="btn btn-danger btn-remove">Eliminar</button></td>
                </tr>`;

            // Función para actualizar precio y subtotal (y total general)
            function actualizarFila(fila) {
                var precio = parseFloat(fila.find('.producto-select option:selected').data('precio') || 0);
                var cantidad = parseInt(fila.find('.cantidad').val() || 1);

                fila.find('.precio').val(precio.toFixed(2));
                fila.find('.subtotal').val((precio * cantidad).toFixed(2));

                actualizarTotalGeneral();
            }

            // Actualiza total general
            function actualizarTotalGeneral() {
                var total = 0;
                $('#tablaProductos tbody tr').each(function () {
                    var subtotal = parseFloat($(this).find('.subtotal').val() || 0);
                    total += subtotal;
                });
                $('#totalGeneral').val(total.toFixed(2));
            }

            // Evento change de producto
            $(document).on('change', '.producto-select', function () {
                actualizarFila($(this).closest('tr'));
            });

            // Evento change de cantidad
            $(document).on('input', '.cantidad', function () {
                actualizarFila($(this).closest('tr'));
            });

            // Agregar nueva fila
            $('#btnAgregar').click(function () {
                $('#tablaProductos tbody').append(filaPlantilla);
            });

            // Eliminar fila
            $(document).on('click', '.btn-remove', function () {
                var fila = $(this).closest('tr');
                var idDetalle = fila.find('.iddetalle').val();

                // Si tiene IdDetalle > 0, significa que existe en la DB y se debe eliminar o marcar para eliminar
                if (idDetalle > 0) {
                    // En un sistema real, aquí enviarías una solicitud AJAX para eliminar
                    // o marcarías la fila para eliminación al guardar.
                    // Por simplicidad, aquí solo se elimina visualmente.
                }

                fila.remove();
                actualizarTotalGeneral();
            });

            // Guardar todos los productos
            $('#btnGuardar').click(function () {
                var detalles = [];

                $('#tablaProductos tbody tr').each(function () {
                    var idDetalle = parseInt($(this).find('.iddetalle').val());
                    var idProducto = $(this).find('.producto-select').val();
                    var cantidad = parseInt($(this).find('.cantidad').val());

                    if (idProducto && cantidad > 0) {
                        detalles.push({
                            IdDetalle: idDetalle, // 0 si es nuevo, > 0 si es existente
                            IdConsumo: idConsumo,
                            IdProducto: parseInt(idProducto),
                            Cantidad: cantidad
                        });
                    }
                });

                if (detalles.length == 0) { alert('No hay detalles válidos para guardar'); return; }

                $.ajax({
                    url: '@Url.Action("EditConsumo", "ConsumoDetalle")', // Usar la nueva acción POST
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(detalles),
                    success: function (res) {
                        if (res.success) {
                            alert(res.message);
                            window.location.href = '@Url.Action("Index")';
                        } else {
                            alert(res.message);
                        }
                    }
                });
            });

            // Inicializar todas las filas al cargar
            $('#tablaProductos tbody tr').each(function () {
                actualizarFila($(this));
            });
        });
    </script>
}